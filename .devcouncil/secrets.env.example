# DevCouncil local provider secrets — TEMPLATE
#
# Copy this file to `.devcouncil/secrets.env` and fill in real values.
# `.devcouncil/secrets.env` is git-ignored and must never be committed.
# Values may also be supplied via real environment variables, which take
# precedence over this file (see src/devcouncil/app/config.py:get_api_key).
#
# Format: KEY=VALUE (one per line; quotes optional; `#` lines are ignored).

# --- LLM provider API key (required) ---
# Set the key matching the `models.provider` in config.yaml.
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DOUBLEWORD_API_KEY=

# --- Ollama (only if provider: ollama; local, no key needed) ---
# Ollama runs locally and needs NO API key.
# Optional: override the default http://localhost:11434/v1 endpoint.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Or use Ollama's native host var (scheme and /v1 are auto-normalized):
# OLLAMA_HOST=localhost:11434
# Recommended: raise the context window so large planning prompts aren't truncated
# (Ollama's default is ~2048-4096; DevCouncil prompts can reach ~15k tokens):
# OLLAMA_NUM_CTX=16384

# --- Vertex AI (only if provider: vertexai) ---
# VERTEXAI_PROJECT=
# VERTEXAI_LOCATION=global
# GOOGLE_CLOUD_PROJECT=

# --- Code-host integration tokens (only if publishing PR/MR reports) ---
# GITHUB_TOKEN=
# GITLAB_TOKEN=
# GITLAB_API_URL=https://gitlab.com/api/v4
